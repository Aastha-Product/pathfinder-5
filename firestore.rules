rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isResourceOwner() {
      return isAuthenticated() && resource.data.author.id == request.auth.uid;
    }

    function isParticipant(userIds) {
      return isAuthenticated() && request.auth.uid in userIds;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if true; // Public profiles
      allow write: if isOwner(userId);
      
      match /resourceProgress/{resourceId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Posts ---
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isResourceOwner(); // Only author can edit/delete

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isResourceOwner();
      }

      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId); // Only like as self
      }
    }

    // --- DM Threads ---
    match /dmThreads/{threadId} {
      allow read: if isParticipant(resource.data.participants);
      allow create: if isAuthenticated(); // Anyone can start a thread
      allow update: if isParticipant(resource.data.participants);

      match /messages/{messageId} {
        allow read: if isParticipant(get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participants);
        allow create: if isParticipant(get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participants);
      }

      match /reads/{userId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Groups ---
    match /groups/{groupId} {
      allow read: if true; // Public groups visible
      allow create: if isAuthenticated();
      allow update: if resource.data.ownerId == request.auth.uid; // Only owner edits group info

      match /members/{userId} {
        allow read: if true;
        allow write: if isOwner(userId); // Join/leave
      }
    }

    // --- Projects (RBAC) ---
    match /projects/{projectId} {
      // Helper to get role
      function getRole() {
        // Assuming members are stored as a map: { uid: 'admin' | 'member' | 'viewer' }
        // Or subcollection. If subcollection, we need get().
        // Let's assume subcollection for scalability as per prompt "projects/{projectId}/members/{uid}"
        return get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
      }

      function isProjectMember() {
        return exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
      }

      function isAdmin() {
        return getRole() == 'admin' || getRole() == 'owner';
      }

      function isMember() {
        return getRole() == 'member' || isAdmin();
      }

      allow read: if isProjectMember(); // Viewers can read project metadata
      allow update, delete: if isAdmin(); // Only admins manage project settings

      match /members/{userId} {
        allow read: if isProjectMember();
        allow write: if isAdmin(); // Only admins add/remove members
      }

      match /board/{taskId} {
        allow read: if isProjectMember();
        allow write: if isMember(); // Members can edit tasks
      }

      match /list/{itemId} {
        allow read: if isProjectMember();
        allow write: if isMember();
      }

      match /timeline/{eventId} {
        allow read: if isProjectMember();
        allow write: if isMember();
      }
    }

    // --- Mock Interviews ---
    match /mockInterviews/{interviewId} {
      function isInterviewParticipant() {
        return request.auth.uid == resource.data.inviter_id || request.auth.uid == resource.data.invitee_id;
      }

      allow read: if isInterviewParticipant();
      allow create: if isAuthenticated();
      allow update: if isInterviewParticipant(); // Status updates

      match /notes/{noteId} {
        allow read: if isInterviewParticipant();
        allow write: if isResourceOwner(); // Only author edits their notes
      }

      match /feedback/{feedbackId} {
        allow read: if isInterviewParticipant();
        allow write: if isResourceOwner(); // Only reviewer writes feedback
      }

      match /aiPracticePlan/latest {
        allow read: if isInterviewParticipant();
        allow write: if false; // Only writable by Cloud Functions (Admin SDK)
      }
    }

    // --- Project Invites ---
    match /projectInvites/{inviteId} {
      allow read: if isAuthenticated(); // Need to read to accept
      allow create: if false; // Created by Cloud Function
      allow update: if false; // Updated by Cloud Function
    }
  }
}
